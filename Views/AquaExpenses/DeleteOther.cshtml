@model SampleMVCApplication.Models.OtherExpense

@{
    ViewBag.Title = "Delete Other Expense";
}

<div class="container mt-4">
    <div class="row">
    <div class="col-md-8 offset-md-2">
       <div class="card border-danger">
    <div class="card-header bg-danger text-white">
         <h3 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Delete Other Expense</h3>
    </div>
 <div class="card-body">
  <div class="alert alert-warning">
       <i class="bi bi-exclamation-triangle-fill"></i>
      <strong>Warning!</strong> Are you sure you want to delete this expense? This action cannot be undone.
      </div>

      <h4>Expense Details:</h4>
   <dl class="row">
   <dt class="col-sm-4">Date:</dt>
      <dd class="col-sm-8">@Model.DateAdded.ToString("MMMM dd, yyyy")</dd>

        <dt class="col-sm-4">Expense Name:</dt>
  <dd class="col-sm-8"><strong>@Model.ExpenseName</strong></dd>

    <dt class="col-sm-4">Category:</dt>
 <dd class="col-sm-8"><span class="badge bg-warning text-dark">@(string.IsNullOrEmpty(Model.Category) ? "General" : Model.Category)</span></dd>

    <dt class="col-sm-4">Price:</dt>
     <dd class="col-sm-8">@Model.Price.ToString("C")</dd>

 <dt class="col-sm-4">Total Amount:</dt>
 <dd class="col-sm-8"><h5 class="text-danger">@Model.TotalAmount.ToString("C")</h5></dd>

<dt class="col-sm-4">Notes:</dt>
<dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Notes) ? "No notes" : Model.Notes)</dd>
    </dl>

   @using (Html.BeginForm("DeleteOther", "AquaExpenses", FormMethod.Post))
 {
 @Html.AntiForgeryToken()
@Html.HiddenFor(m => m.Id)

       <div class="form-group mt-4">
       <button type="submit" class="btn btn-danger btn-lg">
     <i class="bi bi-trash"></i> Yes, Delete This Expense
   </button>
 @Html.ActionLink("No, Keep It", "Index", new { tab = "other" }, new { @class = "btn btn-secondary btn-lg" })
 </div>
  }
    </div>
          </div>

     <div class="mt-3">
    @Html.ActionLink("? Back to Aqua Expenses", "Index", new { tab = "other" }, new { @class = "btn btn-link" })
     </div>
        </div>
    </div>
</div>
