@model SampleMVCApplication.Models.MineralExpense

@{
    ViewBag.Title = "Edit Mineral Expense";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
    <div class="card">
       <div class="card-header bg-warning text-dark">
 <h3 class="mb-0"><i class="bi bi-pencil"></i> Edit Mineral Expense</h3>
</div>
   <div class="card-body">
      @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

  @using (Html.BeginForm("EditMineral", "AquaExpenses", FormMethod.Post, new { @class = "needs-validation" }))
      {
   @Html.AntiForgeryToken()
 @Html.HiddenFor(m => m.Id)
    @Html.HiddenFor(m => m.DateAdded)

  <div class="form-group mb-3">
   @Html.LabelFor(m => m.MineralType, new { @class = "form-label" })
      @Html.TextBoxFor(m => m.MineralType, new { @class = "form-control" })
 @Html.ValidationMessageFor(m => m.MineralType, "", new { @class = "text-danger" })
       </div>

     <div class="row">
  <div class="col-md-6">
 <div class="form-group mb-3">
       @Html.LabelFor(m => m.Quantity, new { @class = "form-label" })
    <div class="input-group">
 @Html.TextBoxFor(m => m.Quantity, new { @class = "form-control", type = "number", step = "0.01", min = "0.01" })
     <span class="input-group-text">kg</span>
    </div>
   @Html.ValidationMessageFor(m => m.Quantity, "", new { @class = "text-danger" })
   </div>
    </div>

      <div class="col-md-6">
       <div class="form-group mb-3">
      @Html.LabelFor(m => m.Price, new { @class = "form-label" })
<div class="input-group">
   <span class="input-group-text">$</span>
   @Html.TextBoxFor(m => m.Price, new { @class = "form-control", type = "number", step = "0.01", min = "0.01" })
       <span class="input-group-text">per kg</span>
       </div>
  @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-danger" })
       </div>
     </div>
    </div>

<div class="form-group mb-3">
 @Html.LabelFor(m => m.Notes, new { @class = "form-label" })
       @Html.TextAreaFor(m => m.Notes, 3, 50, new { @class = "form-control" })
  @Html.ValidationMessageFor(m => m.Notes, "", new { @class = "text-danger" })
</div>

<div class="alert alert-light border">
   <strong>Calculated Total:</strong>
    <span class="text-success fs-4" id="calculatedTotal">@Model.TotalAmount.ToString("C")</span>
        </div>

 <div class="form-group">
      <button type="submit" class="btn btn-warning btn-lg">
    <i class="bi bi-save"></i> Update Mineral Expense
   </button>
 @Html.ActionLink("Cancel", "Index", new { tab = "minerals" }, new { @class = "btn btn-secondary btn-lg" })
   </div>
}
    </div>
            </div>

      <div class="mt-3">
  @Html.ActionLink("? Back to Aqua Expenses", "Index", new { tab = "minerals" }, new { @class = "btn btn-link" })
     </div>
   </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        function calculateTotal() {
      var quantity = parseFloat($('#Quantity').val()) || 0;
    var price = parseFloat($('#Price').val()) || 0;
    var total = quantity * price;
      $('#calculatedTotal').text('$' + total.toFixed(2));
   }

        $(document).ready(function() {
   $('#Quantity, #Price').on('input', calculateTotal);
     });
    </script>
}
