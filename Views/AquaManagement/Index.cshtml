@{
    ViewBag.Title = "Aqua Management - Profit & Loss";
    var dashboard = ViewBag.Dashboard as SampleMVCApplication.Models.AquaManagementDashboardViewModel;
}

<div class="container-fluid mt-3">
    <!-- Page Header -->
    <div class="row mb-4">
    <div class="col-12">
            <h1 class="text-primary">
     <i class="bi bi-graph-up-arrow"></i> Aqua Management Dashboard
    </h1>
  <p class="lead text-muted">Complete Profit & Loss Analysis</p>
        </div>
    </div>

    <!-- Success Message -->
    @if (ViewBag.SuccessMessage != null)
 {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @ViewBag.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
}

    <!-- Profit and Loss Summary - MAIN FEATURE -->
<div class="row mb-4">
        <div class="col-12">
            <div class="card @(dashboard.IsProfitable ? "border-success" : "border-danger") shadow-lg">
    <div class="card-header @(dashboard.IsProfitable ? "bg-success" : "bg-danger") text-white">
            <h3 class="mb-0">
      <i class="bi bi-calculator-fill"></i> Profit & Loss Statement
               </h3>
     </div>
     <div class="card-body">
     <div class="row text-center">
  <div class="col-md-3">
       <div class="p-3">
             <h6 class="text-muted mb-2">TOTAL REVENUE</h6>
    <h2 class="text-success mb-0">
       <i class="bi bi-arrow-up-circle-fill"></i>
            @dashboard.TotalRevenue.ToString("C")
    </h2>
          <small class="text-muted">@dashboard.TotalRevenueEntries sales</small>
       </div>
         </div>
         <div class="col-md-3">
      <div class="p-3">
       <h6 class="text-muted mb-2">TOTAL EXPENSES</h6>
     <h2 class="text-danger mb-0">
              <i class="bi bi-arrow-down-circle-fill"></i>
 @dashboard.TotalExpenses.ToString("C")
            </h2>
         <small class="text-muted">@dashboard.TotalExpenseEntries entries</small>
         </div>
              </div>
       <div class="col-md-1 d-flex align-items-center justify-content-center">
    <h1 class="text-muted mb-0">=</h1>
  </div>
          <div class="col-md-5">
  <div class="p-3 @(dashboard.IsProfitable ? "bg-success" : "bg-danger") bg-opacity-10 rounded">
    <h6 class="text-muted mb-2">
  @(dashboard.IsProfitable ? "NET PROFIT" : "NET LOSS")
                  <i class="bi @(dashboard.IsProfitable ? "bi-emoji-smile" : "bi-emoji-frown")"></i>
      </h6>
           <h1 class="@(dashboard.IsProfitable ? "text-success" : "text-danger") mb-0 fw-bold">
 @dashboard.NetProfitLoss.ToString("C")
          </h1>
   <small class="@(dashboard.IsProfitable ? "text-success" : "text-danger")">
    Profit Margin: @dashboard.ProfitMargin.ToString("N2")%
        </small>
    </div>
      </div>
       </div>
                </div>
 </div>
        </div>
    </div>

    <!-- Revenue Breakdown -->
    <div class="row mb-4">
   <div class="col-md-6">
        <div class="card border-success shadow">
         <div class="card-header bg-success text-white">
          <h4 class="mb-0"><i class="bi bi-cash-coin"></i> Revenue Breakdown</h4>
    </div>
  <div class="card-body">
        <div class="mb-3 pb-3 border-bottom">
       <div class="d-flex justify-content-between align-items-center">
         <div>
    <h5 class="mb-1"><i class="bi bi-water"></i> Prawn Revenue</h5>
             <small class="text-muted">Sales from prawn harvest</small>
    </div>
            <h4 class="text-success mb-0">@dashboard.TotalPrawnRevenue.ToString("C")</h4>
           </div>
    <div class="progress mt-2" style="height: 25px;">
        <div class="progress-bar bg-success" role="progressbar" 
            style="width: @((dashboard.TotalRevenue > 0 ? (dashboard.TotalPrawnRevenue / dashboard.TotalRevenue * 100) : 0).ToString("N2"))%"
          aria-valuenow="@dashboard.TotalPrawnRevenue" aria-valuemin="0" aria-valuemax="@dashboard.TotalRevenue">
       @((dashboard.TotalRevenue > 0 ? (dashboard.TotalPrawnRevenue / dashboard.TotalRevenue * 100) : 0).ToString("N1"))%
   </div>
</div>
    </div>

                <div class="mb-3">
   <div class="d-flex justify-content-between align-items-center">
     <div>
        <h5 class="mb-1"><i class="bi bi-bag"></i> Bag Revenue</h5>
            <small class="text-muted">Sales from packaged products</small>
        </div>
             <h4 class="text-info mb-0">@dashboard.TotalBagRevenue.ToString("C")</h4>
    </div>
                <div class="progress mt-2" style="height: 25px;">
            <div class="progress-bar bg-info" role="progressbar" 
       style="width: @((dashboard.TotalRevenue > 0 ? (dashboard.TotalBagRevenue / dashboard.TotalRevenue * 100) : 0).ToString("N2"))%"
              aria-valuenow="@dashboard.TotalBagRevenue" aria-valuemin="0" aria-valuemax="@dashboard.TotalRevenue">
    @((dashboard.TotalRevenue > 0 ? (dashboard.TotalBagRevenue / dashboard.TotalRevenue * 100) : 0).ToString("N1"))%
        </div>
      </div>
        </div>

        <hr />
         <div class="d-flex justify-content-between align-items-center">
 <h5 class="mb-0">Total Revenue:</h5>
         <h3 class="text-success mb-0 fw-bold">@dashboard.TotalRevenue.ToString("C")</h3>
              </div>
         <div class="mt-3">
              @Html.ActionLink("View Revenue Details ?", "Index", "AquaRevenue", null, new { @class = "btn btn-success w-100" })
     </div>
  </div>
   </div>
 </div>

        <div class="col-md-6">
            <div class="card border-danger shadow">
    <div class="card-header bg-danger text-white">
         <h4 class="mb-0"><i class="bi bi-cash-stack"></i> Expense Breakdown</h4>
                </div>
       <div class="card-body">
          <div class="mb-3 pb-3 border-bottom">
         <div class="d-flex justify-content-between align-items-center">
         <div>
   <h5 class="mb-1"><i class="bi bi-bucket"></i> Feed Expenses</h5>
         <small class="text-muted">Feed purchases</small>
        </div>
        <h4 class="text-info mb-0">@dashboard.TotalFeedExpenses.ToString("C")</h4>
       </div>
      <div class="progress mt-2" style="height: 20px;">
         <div class="progress-bar bg-info" role="progressbar" 
                style="width: @((dashboard.TotalExpenses > 0 ? (dashboard.TotalFeedExpenses / dashboard.TotalExpenses * 100) : 0).ToString("N2"))%">
    @((dashboard.TotalExpenses > 0 ? (dashboard.TotalFeedExpenses / dashboard.TotalExpenses * 100) : 0).ToString("N1"))%
           </div>
              </div>
          </div>

            <div class="mb-3 pb-3 border-bottom">
        <div class="d-flex justify-content-between align-items-center">
            <div>
    <h5 class="mb-1"><i class="bi bi-gem"></i> Mineral Expenses</h5>
     <small class="text-muted">Mineral supplements</small>
 </div>
   <h4 class="text-success mb-0">@dashboard.TotalMineralExpenses.ToString("C")</h4>
     </div>
              <div class="progress mt-2" style="height: 20px;">
            <div class="progress-bar bg-success" role="progressbar" 
           style="width: @((dashboard.TotalExpenses > 0 ? (dashboard.TotalMineralExpenses / dashboard.TotalExpenses * 100) : 0).ToString("N2"))%">
      @((dashboard.TotalExpenses > 0 ? (dashboard.TotalMineralExpenses / dashboard.TotalExpenses * 100) : 0).ToString("N1"))%
          </div>
             </div>
         </div>

         <div class="mb-3">
  <div class="d-flex justify-content-between align-items-center">
                <div>
          <h5 class="mb-1"><i class="bi bi-receipt"></i> Other Expenses</h5>
           <small class="text-muted">Miscellaneous costs</small>
   </div>
      <h4 class="text-warning mb-0">@dashboard.TotalOtherExpenses.ToString("C")</h4>
    </div>
  <div class="progress mt-2" style="height: 20px;">
     <div class="progress-bar bg-warning" role="progressbar" 
           style="width: @((dashboard.TotalExpenses > 0 ? (dashboard.TotalOtherExpenses / dashboard.TotalExpenses * 100) : 0).ToString("N2"))%">
      @((dashboard.TotalExpenses > 0 ? (dashboard.TotalOtherExpenses / dashboard.TotalExpenses * 100) : 0).ToString("N1"))%
</div>
            </div>
            </div>

               <hr />
        <div class="d-flex justify-content-between align-items-center">
         <h5 class="mb-0">Total Expenses:</h5>
      <h3 class="text-danger mb-0 fw-bold">@dashboard.TotalExpenses.ToString("C")</h3>
  </div>
          <div class="mt-3">
         @Html.ActionLink("View Expense Details ?", "Index", "AquaExpenses", null, new { @class = "btn btn-danger w-100" })
        </div>
                </div>
            </div>
 </div>
    </div>

    <!-- Quick Stats Row -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-success shadow">
            <div class="card-body text-center">
           <h6 class="card-title">Prawn Revenue</h6>
  <h3 class="mb-0">@dashboard.TotalPrawnRevenue.ToString("C")</h3>
         <small>Primary income source</small>
    </div>
  </div>
        </div>
        <div class="col-md-3">
        <div class="card text-white bg-info shadow">
                <div class="card-body text-center">
      <h6 class="card-title">Feed Expenses</h6>
        <h3 class="mb-0">@dashboard.TotalFeedExpenses.ToString("C")</h3>
 <small>Largest expense</small>
             </div>
            </div>
   </div>
    <div class="col-md-3">
            <div class="card text-white bg-primary shadow">
         <div class="card-body text-center">
       <h6 class="card-title">Bag Revenue</h6>
       <h3 class="mb-0">@dashboard.TotalBagRevenue.ToString("C")</h3>
        <small>Secondary income</small>
       </div>
      </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white @(dashboard.IsProfitable ? "bg-success" : "bg-danger") shadow">
        <div class="card-body text-center">
           <h6 class="card-title">Profit Margin</h6>
   <h3 class="mb-0">@dashboard.ProfitMargin.ToString("N2")%</h3>
         <small>@(dashboard.IsProfitable ? "Profitable!" : "Operating at loss")</small>
    </div>
            </div>
        </div>
    </div>

    <!-- Financial Summary Table -->
 <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
          <div class="card-header bg-primary text-white">
         <h4 class="mb-0"><i class="bi bi-table"></i> Financial Summary</h4>
      </div>
           <div class="card-body">
             <table class="table table-hover">
     <thead>
           <tr class="table-light">
         <th width="50%">Category</th>
           <th width="25%" class="text-end">Amount</th>
 <th width="25%" class="text-end">Percentage</th>
          </tr>
     </thead>
  <tbody>
      <tr class="table-success">
        <td colspan="3"><strong><i class="bi bi-arrow-up"></i> REVENUE</strong></td>
          </tr>
      <tr>
   <td class="ps-4"><i class="bi bi-water"></i> Prawn Revenue</td>
           <td class="text-end text-success fw-bold">@dashboard.TotalPrawnRevenue.ToString("C")</td>
                <td class="text-end">@((dashboard.TotalRevenue > 0 ? (dashboard.TotalPrawnRevenue / dashboard.TotalRevenue * 100) : 0).ToString("N2"))%</td>
                 </tr>
 <tr>
       <td class="ps-4"><i class="bi bi-bag"></i> Bag Revenue</td>
       <td class="text-end text-success fw-bold">@dashboard.TotalBagRevenue.ToString("C")</td>
 <td class="text-end">@((dashboard.TotalRevenue > 0 ? (dashboard.TotalBagRevenue / dashboard.TotalRevenue * 100) : 0).ToString("N2"))%</td>
  </tr>
        <tr class="table-success fw-bold">
        <td><strong>Total Revenue</strong></td>
  <td class="text-end text-success"><strong>@dashboard.TotalRevenue.ToString("C")</strong></td>
      <td class="text-end"><strong>100.00%</strong></td>
   </tr>
            <tr><td colspan="3">&nbsp;</td></tr>
         <tr class="table-danger">
   <td colspan="3"><strong><i class="bi bi-arrow-down"></i> EXPENSES</strong></td>
         </tr>
    <tr>
     <td class="ps-4"><i class="bi bi-bucket"></i> Feed Expenses</td>
         <td class="text-end text-danger fw-bold">(@dashboard.TotalFeedExpenses.ToString("C"))</td>
           <td class="text-end">@((dashboard.TotalExpenses > 0 ? (dashboard.TotalFeedExpenses / dashboard.TotalExpenses * 100) : 0).ToString("N2"))%</td>
   </tr>
                <tr>
  <td class="ps-4"><i class="bi bi-gem"></i> Mineral Expenses</td>
     <td class="text-end text-danger fw-bold">(@dashboard.TotalMineralExpenses.ToString("C"))</td>
                    <td class="text-end">@((dashboard.TotalExpenses > 0 ? (dashboard.TotalMineralExpenses / dashboard.TotalExpenses * 100) : 0).ToString("N2"))%</td>
      </tr>
  <tr>
          <td class="ps-4"><i class="bi bi-receipt"></i> Other Expenses</td>
              <td class="text-end text-danger fw-bold">(@dashboard.TotalOtherExpenses.ToString("C"))</td>
         <td class="text-end">@((dashboard.TotalExpenses > 0 ? (dashboard.TotalOtherExpenses / dashboard.TotalExpenses * 100) : 0).ToString("N2"))%</td>
  </tr>
        <tr class="table-danger fw-bold">
          <td><strong>Total Expenses</strong></td>
      <td class="text-end text-danger"><strong>(@dashboard.TotalExpenses.ToString("C"))</strong></td>
      <td class="text-end"><strong>100.00%</strong></td>
            </tr>
             <tr><td colspan="3"><hr class="my-2" /></td></tr>
       <tr class="@(dashboard.IsProfitable ? "table-success" : "table-danger") fs-5">
    <td><strong><i class="bi bi-calculator"></i> NET @(dashboard.IsProfitable ? "PROFIT" : "LOSS")</strong></td>
              <td class="text-end @(dashboard.IsProfitable ? "text-success" : "text-danger")">
                     <strong>@dashboard.NetProfitLoss.ToString("C")</strong>
      </td>
           <td class="text-end @(dashboard.IsProfitable ? "text-success" : "text-danger")">
     <strong>@dashboard.ProfitMargin.ToString("N2")%</strong>
              </td>
   </tr>
     </tbody>
  </table>
    </div>
      </div>
        </div>
    </div>

    <!-- Quick Action Buttons -->
    <div class="row mb-4">
        <div class="col-12">
      <div class="card shadow">
     <div class="card-header bg-light">
      <h4 class="mb-0"><i class="bi bi-lightning-fill"></i> Quick Actions</h4>
           </div>
        <div class="card-body">
         <div class="row">
           <div class="col-md-6 mb-3">
    <h5 class="text-success"><i class="bi bi-plus-circle"></i> Add Revenue</h5>
           <div class="btn-group w-100" role="group">
       @Html.ActionLink("Add Prawn Sale", "CreatePrawn", "AquaRevenue", null, new { @class = "btn btn-success" })
   @Html.ActionLink("Add Bag Sale", "CreateBag", "AquaRevenue", null, new { @class = "btn btn-info" })
        </div>
        </div>
     <div class="col-md-6 mb-3">
       <h5 class="text-danger"><i class="bi bi-dash-circle"></i> Add Expenses</h5>
   <div class="btn-group w-100" role="group">
      @Html.ActionLink("Add Feed", "CreateFeed", "AquaExpenses", null, new { @class = "btn btn-outline-info btn-sm" })
        @Html.ActionLink("Add Mineral", "CreateMineral", "AquaExpenses", null, new { @class = "btn btn-outline-success btn-sm" })
                @Html.ActionLink("Add Other", "CreateOther", "AquaExpenses", null, new { @class = "btn btn-outline-warning btn-sm" })
       </div>
      </div>
          </div>
          </div>
            </div>
        </div>
    </div>

    <!-- Performance Indicator -->
    <div class="row mb-4">
        <div class="col-12">
 <div class="alert @(dashboard.IsProfitable ? "alert-success" : "alert-danger") shadow">
      <div class="row align-items-center">
             <div class="col-md-8">
       <h4 class="alert-heading">
    <i class="bi @(dashboard.IsProfitable ? "bi-graph-up" : "bi-graph-down")"></i>
          @(dashboard.IsProfitable ? "Business Performance: PROFITABLE" : "Business Performance: LOSS")
   </h4>
          <p class="mb-0">
             @if (dashboard.IsProfitable)
   {
      <text>
            Your aquaculture business is performing well with a profit margin of <strong>@dashboard.ProfitMargin.ToString("N2")%</strong>.
     Net profit: <strong>@dashboard.NetProfitLoss.ToString("C")</strong>
        </text>
     }
           else
    {
       <text>
       Your expenses exceed revenue. Current loss: <strong>@dashboard.NetProfitLoss.ToString("C")</strong>.
         Consider reviewing your cost structure or increasing revenue.
        </text>
         }
 </p>
</div>
     <div class="col-md-4 text-end">
        <div class="display-4 @(dashboard.IsProfitable ? "text-success" : "text-danger")">
         <i class="bi @(dashboard.IsProfitable ? "bi-emoji-smile-fill" : "bi-emoji-frown-fill")"></i>
        </div>
       </div>
        </div>
      </div>
  </div>
    </div>

    <!-- Navigation Cards -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card border-success shadow-sm h-100">
         <div class="card-body text-center">
    <div class="display-1 text-success mb-3">
        <i class="bi bi-arrow-up-circle"></i>
    </div>
<h3 class="card-title">Manage Revenue</h3>
           <p class="card-text">Track prawn and bag sales, view revenue breakdown</p>
        <div class="d-grid gap-2">
      @Html.ActionLink("Go to Aqua Revenue ?", "Index", "AquaRevenue", null, new { @class = "btn btn-success btn-lg" })
            </div>
       </div>
       </div>
        </div>
  <div class="col-md-6">
    <div class="card border-danger shadow-sm h-100">
         <div class="card-body text-center">
<div class="display-1 text-danger mb-3">
         <i class="bi bi-arrow-down-circle"></i>
   </div>
         <h3 class="card-title">Manage Expenses</h3>
      <p class="card-text">Track feed, minerals, and other costs</p>
       <div class="d-grid gap-2">
       @Html.ActionLink("Go to Aqua Expenses ?", "Index", "AquaExpenses", null, new { @class = "btn btn-danger btn-lg" })
          </div>
 </div>
</div>
        </div>
    </div>

    <!-- Last Updated -->
    <div class="row">
     <div class="col-12">
      <div class="card bg-light">
         <div class="card-body">
  <p class="mb-0 text-center text-muted">
           <i class="bi bi-clock-history"></i> 
        Dashboard last updated: @dashboard.LastUpdated.ToString("MMMM dd, yyyy 'at' h:mm:ss tt")
        <span class="ms-3">|</span>
         <span class="ms-3">
            <i class="bi bi-file-earmark-text"></i> 
           Total Transactions: @(dashboard.TotalRevenueEntries + dashboard.TotalExpenseEntries)
       </span>
    </p>
          </div>
       </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
 // Auto-dismiss alerts after 5 seconds
        setTimeout(function() {
          $('.alert-dismissible').fadeOut('slow');
      }, 5000);

// Refresh page every 5 minutes to update data
      setTimeout(function() {
      location.reload();
  }, 300000); // 5 minutes
    </script>
}
