@model SampleMVCApplication.Models.BagRevenue

@{
    ViewBag.Title = "Add Bag Sale";
}

<div class="container mt-4">
    <div class="row">
 <div class="col-md-8 offset-md-2">
   <div class="card">
<div class="card-header bg-info text-white">
     <h3 class="mb-0"><i class="bi bi-bag"></i> Add New Bag Sale</h3>
        </div>
 <div class="card-body">
  @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

    @using (Html.BeginForm("CreateBag", "AquaRevenue", FormMethod.Post, new { @class = "needs-validation" }))
    {
      @Html.AntiForgeryToken()

   <div class="row">
  <div class="col-md-6">
    <div class="form-group mb-3">
   @Html.LabelFor(m => m.BagType, new { @class = "form-label" })
  @if (ViewBag.BagTypes != null && ((System.Collections.Generic.List<string>)ViewBag.BagTypes).Count > 0)
       {
    @Html.DropDownListFor(m => m.BagType,
new SelectList(ViewBag.BagTypes),
        "-- Select or type new type --",
    new { @class = "form-select" })
 }
     else
     {
       @Html.TextBoxFor(m => m.BagType, new { @class = "form-control", placeholder = "e.g., Small (5kg), Medium (10kg)" })
     }
  @Html.ValidationMessageFor(m => m.BagType, "", new { @class = "text-danger" })
  </div>
</div>

<div class="col-md-6">
<div class="form-group mb-3">
      @Html.LabelFor(m => m.BuyerName, new { @class = "form-label" })
     @Html.TextBoxFor(m => m.BuyerName, new { @class = "form-control", placeholder = "Buyer or company name" })
@Html.ValidationMessageFor(m => m.BuyerName, "", new { @class = "text-danger" })
</div>
   </div>
      </div>

<div class="row">
   <div class="col-md-6">
   <div class="form-group mb-3">
@Html.LabelFor(m => m.NumberOfBags, new { @class = "form-label" })
 <div class="input-group">
  @Html.TextBoxFor(m => m.NumberOfBags, new { @class = "form-control", type = "number", min = "1", placeholder = "0" })
 <span class="input-group-text">bags</span>
    </div>
  @Html.ValidationMessageFor(m => m.NumberOfBags, "", new { @class = "text-danger" })
    <small class="form-text text-muted">Total number of bags sold</small>
 </div>
      </div>

 <div class="col-md-6">
 <div class="form-group mb-3">
 @Html.LabelFor(m => m.PricePerBag, new { @class = "form-label" })
   <div class="input-group">
        <span class="input-group-text">$</span>
 @Html.TextBoxFor(m => m.PricePerBag, new { @class = "form-control", type = "number", step = "0.01", min = "0.01", placeholder = "0.00" })
     <span class="input-group-text">per bag</span>
    </div>
 @Html.ValidationMessageFor(m => m.PricePerBag, "", new { @class = "text-danger" })
     <small class="form-text text-muted">Selling price per bag</small>
  </div>
    </div>
   </div>

  <div class="form-group mb-3">
    @Html.LabelFor(m => m.Notes, new { @class = "form-label" })
     @Html.TextAreaFor(m => m.Notes, 3, 50, new { @class = "form-control", placeholder = "Optional notes about this sale" })
        @Html.ValidationMessageFor(m => m.Notes, "", new { @class = "text-danger" })
  </div>

   <div class="alert alert-info border">
     <strong>Calculated Total Revenue:</strong>
        <span class="text-success fs-4" id="calculatedTotal">$0.00</span>
   </div>

       <div class="form-group">
   <button type="submit" class="btn btn-info btn-lg">
  <i class="bi bi-save"></i> Save Bag Revenue
  </button>
    @Html.ActionLink("Cancel", "Index", new { tab = "bag" }, new { @class = "btn btn-secondary btn-lg" })
     </div>
 }
     </div>
  </div>

      <div class="mt-3">
    @Html.ActionLink("? Back to Aqua Revenue", "Index", new { tab = "bag" }, new { @class = "btn btn-link" })
        </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        // Calculate total revenue dynamically
function calculateTotal() {
var quantity = parseInt($('#NumberOfBags').val()) || 0;
  var price = parseFloat($('#PricePerBag').val()) || 0;
 var total = quantity * price;
     $('#calculatedTotal').text('$' + total.toFixed(2));
        }

        $(document).ready(function() {
      $('#NumberOfBags, #PricePerBag').on('input', calculateTotal);
  calculateTotal();
        });
    </script>
}
