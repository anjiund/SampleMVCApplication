@model SampleMVCApplication.Models.PrawnRevenue

@{
    ViewBag.Title = "Add Prawn Sale";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
     <div class="card-header bg-success text-white">
        <h3 class="mb-0"><i class="bi bi-water"></i> Add New Prawn Sale</h3>
  </div>
<div class="card-body">
    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

 @using (Html.BeginForm("CreatePrawn", "AquaRevenue", FormMethod.Post, new { @class = "needs-validation" }))
       {
   @Html.AntiForgeryToken()

<div class="row">
   <div class="col-md-6">
 <div class="form-group mb-3">
 @Html.LabelFor(m => m.PrawnGrade, new { @class = "form-label" })
        @if (ViewBag.PrawnGrades != null && ((System.Collections.Generic.List<string>)ViewBag.PrawnGrades).Count > 0)
     {
      @Html.DropDownListFor(m => m.PrawnGrade,
       new SelectList(ViewBag.PrawnGrades),
        "-- Select or type new grade --",
   new { @class = "form-select" })
      }
      else
   {
      @Html.TextBoxFor(m => m.PrawnGrade, new { @class = "form-control", placeholder = "e.g., Grade A, Grade B" })
        }
 @Html.ValidationMessageFor(m => m.PrawnGrade, "", new { @class = "text-danger" })
    </div>
    </div>

<div class="col-md-6">
     <div class="form-group mb-3">
    @Html.LabelFor(m => m.BuyerName, new { @class = "form-label" })
  @Html.TextBoxFor(m => m.BuyerName, new { @class = "form-control", placeholder = "Buyer or company name" })
   @Html.ValidationMessageFor(m => m.BuyerName, "", new { @class = "text-danger" })
         </div>
   </div>
   </div>

   <div class="row">
 <div class="col-md-6">
     <div class="form-group mb-3">
  @Html.LabelFor(m => m.PrawnQuantity, new { @class = "form-label" })
  <div class="input-group">
    @Html.TextBoxFor(m => m.PrawnQuantity, new { @class = "form-control", type = "number", step = "0.01", min = "0.01", placeholder = "0.00" })
      <span class="input-group-text">kg</span>
  </div>
     @Html.ValidationMessageFor(m => m.PrawnQuantity, "", new { @class = "text-danger" })
   <small class="form-text text-muted">Total prawn quantity sold</small>
     </div>
</div>

    <div class="col-md-6">
      <div class="form-group mb-3">
       @Html.LabelFor(m => m.PricePerKg, new { @class = "form-label" })
     <div class="input-group">
  <span class="input-group-text">$</span>
   @Html.TextBoxFor(m => m.PricePerKg, new { @class = "form-control", type = "number", step = "0.01", min = "0.01", placeholder = "0.00" })
   <span class="input-group-text">per kg</span>
      </div>
  @Html.ValidationMessageFor(m => m.PricePerKg, "", new { @class = "text-danger" })
   <small class="form-text text-muted">Selling price per kilogram</small>
   </div>
    </div>
   </div>

<div class="form-group mb-3">
 @Html.LabelFor(m => m.Notes, new { @class = "form-label" })
       @Html.TextAreaFor(m => m.Notes, 3, 50, new { @class = "form-control", placeholder = "Optional notes about this sale" })
  @Html.ValidationMessageFor(m => m.Notes, "", new { @class = "text-danger" })
        </div>

    <div class="alert alert-success border">
     <strong>Calculated Total Revenue:</strong>
   <span class="text-success fs-4" id="calculatedTotal">$0.00</span>
  </div>

   <div class="form-group">
       <button type="submit" class="btn btn-success btn-lg">
 <i class="bi bi-save"></i> Save Prawn Revenue
       </button>
 @Html.ActionLink("Cancel", "Index", new { tab = "prawn" }, new { @class = "btn btn-secondary btn-lg" })
    </div>
      }
     </div>
  </div>

   <div class="mt-3">
   @Html.ActionLink("? Back to Aqua Revenue", "Index", new { tab = "prawn" }, new { @class = "btn btn-link" })
  </div>
    </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
     // Calculate total revenue dynamically
        function calculateTotal() {
    var quantity = parseFloat($('#PrawnQuantity').val()) || 0;
       var price = parseFloat($('#PricePerKg').val()) || 0;
     var total = quantity * price;
       $('#calculatedTotal').text('$' + total.toFixed(2));
  }

  $(document).ready(function() {
    $('#PrawnQuantity, #PricePerKg').on('input', calculateTotal);
       calculateTotal();
        });
    </script>
}
