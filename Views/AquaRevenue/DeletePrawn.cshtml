@model SampleMVCApplication.Models.PrawnRevenue

@{
    ViewBag.Title = "Delete Prawn Sale";
}

<div class="container mt-4">
    <div class="row">
   <div class="col-md-8 offset-md-2">
       <div class="card border-danger">
        <div class="card-header bg-danger text-white">
   <h3 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Delete Prawn Sale</h3>
     </div>
        <div class="card-body">
   <div class="alert alert-warning">
     <i class="bi bi-exclamation-triangle-fill"></i>
       <strong>Warning!</strong> Are you sure you want to delete this prawn sale record? This action cannot be undone.
      </div>

    <h4>Sale Details:</h4>
       <dl class="row">
 <dt class="col-sm-4">Sale Date:</dt>
 <dd class="col-sm-8">@Model.SaleDate.ToString("MMMM dd, yyyy")</dd>

  <dt class="col-sm-4">Prawn Grade:</dt>
      <dd class="col-sm-8"><span class="badge bg-success">@(string.IsNullOrEmpty(Model.PrawnGrade) ? "Standard" : Model.PrawnGrade)</span></dd>

 <dt class="col-sm-4">Quantity:</dt>
     <dd class="col-sm-8"><strong>@Model.PrawnQuantity.ToString("N2") kg</strong></dd>

  <dt class="col-sm-4">Price per kg:</dt>
    <dd class="col-sm-8">@Model.PricePerKg.ToString("C")</dd>

  <dt class="col-sm-4">Total Revenue:</dt>
      <dd class="col-sm-8"><h5 class="text-success">@Model.TotalRevenue.ToString("C")</h5></dd>

    <dt class="col-sm-4">Buyer:</dt>
     <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.BuyerName) ? "Not specified" : Model.BuyerName)</dd>

        <dt class="col-sm-4">Notes:</dt>
<dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Notes) ? "No notes" : Model.Notes)</dd>
    </dl>

@using (Html.BeginForm("DeletePrawn", "AquaRevenue", FormMethod.Post))
    {
@Html.AntiForgeryToken()
@Html.HiddenFor(m => m.Id)

<div class="form-group mt-4">
    <button type="submit" class="btn btn-danger btn-lg">
      <i class="bi bi-trash"></i> Yes, Delete This Revenue
   </button>
 @Html.ActionLink("No, Keep It", "Index", new { tab = "prawn" }, new { @class = "btn btn-secondary btn-lg" })
  </div>
    }
    </div>
   </div>

    <div class="mt-3">
 @Html.ActionLink("? Back to Aqua Revenue", "Index", new { tab = "prawn" }, new { @class = "btn btn-link" })
 </div>
        </div>
    </div>
</div>
