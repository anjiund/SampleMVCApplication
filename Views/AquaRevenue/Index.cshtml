@{
    ViewBag.Title = "Aqua Revenue";
    var dashboard = ViewBag.Dashboard as SampleMVCApplication.Models.AquaRevenueDashboardViewModel;
  var activeTab = ViewBag.ActiveTab as string ?? "prawn";
}

<div class="container-fluid mt-3">
    <!-- Page Header -->
  <div class="row mb-4">
        <div class="col-12">
       <h1 class="text-success">
         <i class="bi bi-cash-coin"></i> Aqua Revenue
            </h1>
   <p class="lead text-muted">Track your aquaculture revenue streams</p>
      </div>
 </div>

    <!-- Success Message -->
    @if (ViewBag.SuccessMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill"></i> @ViewBag.SuccessMessage
       <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
 </div>
    }

    <!-- Summary Cards -->
    <div class="row mb-4">
      <div class="col-md-4">
     <div class="card text-white bg-success">
     <div class="card-body">
     <h5 class="card-title">Prawn Revenue</h5>
   <h3 class="mb-0">@dashboard.TotalPrawnRevenue.ToString("C")</h3>
   <small>@dashboard.PrawnRevenueCount sales</small>
        </div>
   </div>
        </div>
     <div class="col-md-4">
 <div class="card text-white bg-info">
         <div class="card-body">
    <h5 class="card-title">Bag Revenue</h5>
         <h3 class="mb-0">@dashboard.TotalBagRevenue.ToString("C")</h3>
       <small>@dashboard.BagRevenueCount sales</small>
    </div>
  </div>
   </div>
<div class="col-md-4">
  <div class="card text-white bg-primary">
     <div class="card-body">
     <h5 class="card-title">Total Revenue</h5>
  <h3 class="mb-0">@dashboard.GrandTotal.ToString("C")</h3>
    <small>All revenue</small>
      </div>
   </div>
        </div>
    </div>

    <!-- Tabs Navigation -->
    <ul class="nav nav-tabs" id="revenueTabs" role="tablist">
  <li class="nav-item" role="presentation">
      <a class="nav-link @(activeTab == "prawn" ? "active" : "")" 
   href="@Url.Action("Index", new { tab = "prawn" })">
    <i class="bi bi-?"></i> Prawn Revenue
</a>
        </li>
   <li class="nav-item" role="presentation">
 <a class="nav-link @(activeTab == "bag" ? "active" : "")" 
      href="@Url.Action("Index", new { tab = "bag" })">
     <i class="bi bi-bag"></i> Bag Revenue
    </a>
   </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content border border-top-0 p-4 bg-white" id="revenueTabContent">
        
     <!-- PRAWN REVENUE TAB -->
     <div class="tab-pane fade @(activeTab == "prawn" ? "show active" : "")" id="prawn" role="tabpanel">
       <div class="d-flex justify-content-between align-items-center mb-3">
         <h3><i class="bi bi-water"></i> Prawn Revenue</h3>
       @Html.ActionLink("Add New Prawn Sale", "CreatePrawn", null, new { @class = "btn btn-success" })
   </div>

            @{
      var prawnRevenues = ViewBag.PrawnRevenues as System.Collections.Generic.List<SampleMVCApplication.Models.PrawnRevenue>;
  }

            @if (prawnRevenues.Count == 0)
     {
     <div class="alert alert-info">
    <i class="bi bi-info-circle"></i> No prawn revenue recorded yet. 
  @Html.ActionLink("Add your first prawn sale", "CreatePrawn").
    </div>
 }
      else
          {
          <div class="table-responsive">
    <table class="table table-striped table-hover">
     <thead class="table-dark">
<tr>
    <th>Sale Date</th>
  <th>Prawn Grade</th>
         <th>Quantity (kg)</th>
      <th>Price/kg</th>
       <th>Total Revenue</th>
         <th>Buyer</th>
      <th>Notes</th>
   <th>Actions</th>
      </tr>
    </thead>
<tbody>
       @foreach (var item in prawnRevenues)
{
      <tr>
        <td>@item.SaleDate.ToString("MMM dd, yyyy")</td>
       <td><span class="badge bg-success">@(string.IsNullOrEmpty(item.PrawnGrade) ? "Standard" : item.PrawnGrade)</span></td>
 <td class="text-end">@item.PrawnQuantity.ToString("N2")</td>
       <td class="text-end">@item.PricePerKg.ToString("C")</td>
  <td class="text-end"><strong class="text-success">@item.TotalRevenue.ToString("C")</strong></td>
   <td>@(string.IsNullOrEmpty(item.BuyerName) ? "-" : item.BuyerName)</td>
        <td>@(string.IsNullOrEmpty(item.Notes) ? "-" : item.Notes)</td>
  <td>
 @Html.ActionLink("Edit", "EditPrawn", new { id = item.Id }, new { @class = "btn btn-sm btn-warning" })
       @Html.ActionLink("Delete", "DeletePrawn", new { id = item.Id }, new { @class = "btn btn-sm btn-danger" })
    </td>
  </tr>
   }
     </tbody>
      <tfoot>
   <tr class="table-success">
    <td colspan="4" class="text-end"><strong>Total Prawn Revenue:</strong></td>
  <td class="text-end"><strong class="text-success">@dashboard.TotalPrawnRevenue.ToString("C")</strong></td>
 <td colspan="3"></td>
  </tr>
        </tfoot>
         </table>
     </div>
      }
        </div>

        <!-- BAG REVENUE TAB -->
        <div class="tab-pane fade @(activeTab == "bag" ? "show active" : "")" id="bag" role="tabpanel">
     <div class="d-flex justify-content-between align-items-center mb-3">
   <h3><i class="bi bi-bag"></i> Bag Revenue</h3>
            @Html.ActionLink("Add New Bag Sale", "CreateBag", null, new { @class = "btn btn-info" })
         </div>

            @{
    var bagRevenues = ViewBag.BagRevenues as System.Collections.Generic.List<SampleMVCApplication.Models.BagRevenue>;
 }

 @if (bagRevenues.Count == 0)
            {
 <div class="alert alert-info">
       <i class="bi bi-info-circle"></i> No bag revenue recorded yet. 
     @Html.ActionLink("Add your first bag sale", "CreateBag").
      </div>
}
            else
         {
  <div class="table-responsive">
        <table class="table table-striped table-hover">
        <thead class="table-dark">
   <tr>
      <th>Sale Date</th>
      <th>Bag Type</th>
       <th>Number of Bags</th>
   <th>Price/Bag</th>
  <th>Total Revenue</th>
       <th>Buyer</th>
  <th>Notes</th>
     <th>Actions</th>
       </tr>
    </thead>
     <tbody>
    @foreach (var item in bagRevenues)
 {
    <tr>
  <td>@item.SaleDate.ToString("MMM dd, yyyy")</td>
       <td><span class="badge bg-info">@(string.IsNullOrEmpty(item.BagType) ? "Standard" : item.BagType)</span></td>
      <td class="text-end">@item.NumberOfBags</td>
 <td class="text-end">@item.PricePerBag.ToString("C")</td>
    <td class="text-end"><strong class="text-success">@item.TotalRevenue.ToString("C")</strong></td>
<td>@(string.IsNullOrEmpty(item.BuyerName) ? "-" : item.BuyerName)</td>
     <td>@(string.IsNullOrEmpty(item.Notes) ? "-" : item.Notes)</td>
       <td>
      @Html.ActionLink("Edit", "EditBag", new { id = item.Id }, new { @class = "btn btn-sm btn-warning" })
@Html.ActionLink("Delete", "DeleteBag", new { id = item.Id }, new { @class = "btn btn-sm btn-danger" })
       </td>
  </tr>
  }
      </tbody>
       <tfoot>
     <tr class="table-info">
         <td colspan="4" class="text-end"><strong>Total Bag Revenue:</strong></td>
   <td class="text-end"><strong class="text-success">@dashboard.TotalBagRevenue.ToString("C")</strong></td>
     <td colspan="3"></td>
      </tr>
      </tfoot>
          </table>
  </div>
    }
   </div>
    </div>

    <!-- Grand Total Summary -->
    <div class="row mt-4">
 <div class="col-12">
       <div class="card border-success">
     <div class="card-header bg-success text-white">
       <h4 class="mb-0"><i class="bi bi-calculator"></i> Revenue Summary</h4>
    </div>
        <div class="card-body">
          <div class="row">
    <div class="col-md-4">
   <p class="mb-1 text-muted">Prawn Revenue:</p>
      <h5 class="text-success">@dashboard.TotalPrawnRevenue.ToString("C")</h5>
         </div>
    <div class="col-md-4">
      <p class="mb-1 text-muted">Bag Revenue:</p>
    <h5 class="text-info">@dashboard.TotalBagRevenue.ToString("C")</h5>
   </div>
         <div class="col-md-4">
      <p class="mb-1 text-muted">Total Revenue:</p>
    <h4 class="text-success"><strong>@dashboard.GrandTotal.ToString("C")</strong></h4>
     </div>
     </div>
    <hr />
  <p class="mb-0 text-muted">
    <i class="bi bi-clock"></i> Last updated: @dashboard.LastUpdated.ToString("MMM dd, yyyy 'at' h:mm tt")
            </p>
    </div>
     </div>
  </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-dismiss alerts after 5 seconds
     setTimeout(function() {
      $('.alert-dismissible').fadeOut('slow');
        }, 5000);
    </script>
}
