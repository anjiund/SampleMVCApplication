@model SampleMVCApplication.Models.ContactFormModel

@{
  ViewBag.Title = "Contact Form";
}

<main aria-labelledby="title">
    <h2 id="title">Contact Us</h2>
    <p class="lead">Please fill out the form below to send us a message.</p>

    @* Display validation summary for any model errors *@
  @Html.ValidationSummary(false, "", new { @class = "alert alert-danger" })

    @* Form with POST method - data flows from View ? Controller *@
    @using (Html.BeginForm("ContactForm", "Home", FormMethod.Post, new { @class = "needs-validation" }))
    {
   @Html.AntiForgeryToken() @* Security token *@

        <div class="form-group mb-3">
   @* Label: Displays the Display attribute or property name *@
       @Html.LabelFor(m => m.Name, new { @class = "form-label" })
 
       @* Input: Creates input field, bound to model property *@
   @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Enter your name" })
            
            @* Validation message: Shows error if validation fails *@
   @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
  @Html.LabelFor(m => m.Email, new { @class = "form-label" })
   @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "your.email@example.com", type = "email" })
   @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
      </div>

      <div class="form-group mb-3">
        @Html.LabelFor(m => m.Subject, new { @class = "form-label" })
   @Html.TextBoxFor(m => m.Subject, new { @class = "form-control", placeholder = "What is this regarding?" })
   @Html.ValidationMessageFor(m => m.Subject, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
  @Html.LabelFor(m => m.Message, new { @class = "form-label" })
   @Html.TextAreaFor(m => m.Message, 5, 50, new { @class = "form-control", placeholder = "Enter your message here..." })
   @Html.ValidationMessageFor(m => m.Message, "", new { @class = "text-danger" })
      </div>

        <div class="form-group">
         <button type="submit" class="btn btn-primary">
      <i class="bi bi-send"></i> Send Message
            </button>
            @Html.ActionLink("Cancel", "Index", "Home", null, new { @class = "btn btn-secondary" })
        </div>
    }

    <hr class="my-4" />
    
    <div class="alert alert-info">
        <h5>How This Form Works (MVC Flow):</h5>
    <ol>
   <li><strong>View ? Controller:</strong> When you submit, form data is sent as POST request</li>
   <li><strong>Model Binding:</strong> ASP.NET automatically maps form fields to ContactFormModel properties</li>
          <li><strong>Validation:</strong> Model attributes validate data (Required, Email, StringLength, etc.)</li>
            <li><strong>Controller Logic:</strong> If valid, processes data; if invalid, returns form with errors</li>
   <li><strong>Controller ? View:</strong> Sends result back to display success or errors</li>
  </ol>
    </div>
</main>

@section Scripts {
@Scripts.Render("~/bundles/jqueryval") @* Client-side validation *@
}
